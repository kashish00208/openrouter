generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String

  apiKey             ApiKey?
  credit             Credit?
  onrampTransactions OnrampTransaction[]
  conversations      Conversation[]
}

model ApiKey {
  id       String  @id @default(uuid())
  apiKey   String  @unique
  disabled Boolean @default(false)

  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  conversations Conversation[]
}

model Company {
  id      String @id @default(uuid())
  name    String
  website String @unique

  models Model[]
}

model Model {
  id   String @id @default(uuid())
  name String

  company   Company @relation(fields: [companyId], references: [id])
  companyId String

  providerMappings ModelProviderMapping[]
}

model Provider {
  id      String @id @default(uuid())
  name    String
  website String @unique

  modelMappings ModelProviderMapping[]
}

model ModelProviderMapping {
  id String @id @default(uuid())

  model   Model  @relation(fields: [modelId], references: [id])
  modelId String

  provider   Provider @relation(fields: [providerId], references: [id])
  providerId String

  inputTokenCost  Float
  outputTokenCost Float

  conversations Conversation[]
}

model Credit {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id])
  userId String @unique
}

model OnrampTransaction {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  amount Int
  status String
}

model Conversation {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  apiKey   ApiKey @relation(fields: [apiKeyId], references: [id])
  apiKeyId String

  modelProviderMapping   ModelProviderMapping @relation(fields: [modelProviderMappingId], references: [id])
  modelProviderMappingId String

  input            String
  output           String
  inputTokenCount  Int
  outputTokenCount Int
}
